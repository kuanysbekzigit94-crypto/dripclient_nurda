# =============================================
# PAY APP BOT — Environment Variables Example
# =============================================
# Осы файлды .env деп атап, мәндерді толтырыңыз
# Copy this file as .env and fill in the values

# Telegram Bot Token (BotFather-дан алыңыз)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Admin Telegram IDs (үтірмен бөліңіз / comma-separated)
ADMIN_IDS=[123456789, 987654321]

# Kaspi payment details
KASPI_PHONE=+7XXXXXXXXXX
KASPI_RECEIVER=Аты-жөні

# Database URL (SQLite - default, PostgreSQL - production)
DATABASE_URL=sqlite+aiosqlite:///database.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/payappbot

# Optional links
OFFICIAL_WEBSITE=https://example.com
DOWNLOAD_LINK=https://example.com/download
TELEGRAM_CHANNEL=https://t.me/your_channel
CONTACT_ADMIN=https://t.me/your_admin
